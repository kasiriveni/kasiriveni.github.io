{
	"env": {
		"browser": true,
		"es2021": true
	},
	"extends": ["eslint:recommended", "plugin:jest/recommended"],
	"plugins": ["jest"],
	"parserOptions": {
		"ecmaVersion": 12,
		"sourceType": "module"
	},
	"rules": {},
	"overrides": [
		{
			"files": ["src/test/**/*.js"],
			"env": {
				"jest": true
			}
		},
		{
			"files": ["jest.config.js"],
			"env": {
				"node": true
			}
		}
	]
}
